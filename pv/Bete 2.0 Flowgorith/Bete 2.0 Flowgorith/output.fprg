ound ---&quot;" /><output expression="&quot;--- MESAJ PRIMIT: WIN ---&quot;" /><output expression="&quot;Program oprit&quot;" /><output expression="&quot;--- MESAJ PRIMIT: Game over ---&quot;" /><output expression="&quot;Program oprit&quot;" /><output expression="&quot;--- MESAJ PRIMIT: A start game ---&quot;" /><while expression="true"><assign variable="Weapondamage" expression="(30 + (30 * (0.25 * 0)))" /></while><output expression="&quot;--- MESAJ PRIMIT: A start game ---&quot;" /><assign variable="attackcd" expression="1" /><while expression="true"><if expression="(0 &amp;&amp; (attackcd = 1))"><then><output expression="&quot;Sprite visible&quot;" /><assign variable="xpos" expression="xmain" /><assign variable="ypos" expression="ymain" /><assign variable="attackcd" expression="0" /><for variable="i" start="1" end="5" direction="inc" step="1"><assign variable="xpos" expression="xpos + cos((90 - directie) * 3.141592653589793 / 180) * (10 + (10 * (0.25 * 0)))" /><assign variable="ypos" expression="ypos + sin((90 - directie) * 3.141592653589793 / 180) * (10 + (10 * (0.25 * 0)))" /></for><output expression="&quot;Sprite ascuns&quot;" /><assign variable="attackcd" expression="1" /><output expression="&quot;Asteptand 0.5 secunde&quot;" /></then><else /></if></while><assign variable="xpos" expression="0" /><assign variable="ypos" expression="0" /><output expression="&quot;Sprite ascuns&quot;" /><output expression="&quot;--- MESAJ PRIMIT: Invincibility sprite ---&quot;" /><output expression="&quot;--- MESAJ PRIMIT: Normal sprite ---&quot;" /><output expression="&quot;--- MESAJ PRIMIT: A start game ---&quot;" /><output expression="&quot;Sprite visible&quot;" /><while expression="true"><assign variable="xpos" expression="xmain" /><assign variable="ypos" expression="ymain" /></while><output expression="&quot;--- MESAJ PRIMIT: Game over ---&quot;" /><output expression="&quot;Sprite ascuns&quot;" /><output expression="&quot;Sprite ascuns&quot;" /><assign variable="xpos" expre