<flowgorithm fileversion="4.2"><attributes /><function name="Main" type="None" variable=""><parameters /><body><declare name="running" type="Boolean" array="False" size="" /><declare name="Area" type="Real" array="False" size="" /><assign variable="Area" expression="0" /><declare name="Bombskill" type="Real" array="False" size="" /><assign variable="Bombskill" expression="0" /><declare name="Bombx" type="Real" array="False" size="" /><assign variable="Bombx" expression="0" /><declare name="Bomby" type="Real" array="False" size="" /><assign variable="Bomby" expression="0" /><declare name="Bossattack" type="Real" array="False" size="" /><assign variable="Bossattack" expression="0" /><declare name="Coins" type="Real" array="False" size="" /><assign variable="Coins" expression="0" /><declare name="Dashcd" type="Real" array="False" size="" /><assign variable="Dashcd" expression="0" /><declare name="EnemiesKilled" type="Real" array="False" size="" /><assign variable="EnemiesKilled" expression="0" /><declare name="Explosiontype" type="Real" array="False" size="" /><assign variable="Explosiontype" expression="0" /><declare name="Health" type="Real" array="False" size="" /><assign variable="Health" expression="0" /><declare name="Incombat" type="Real" array="False" size="" /><assign variable="Incombat" expression="0" /><declare name="Inshop" type="Real" array="False" size="" /><assign variable="Inshop" expression="0" /><declare name="Invincible" type="Real" array="False" size="" /><assign variable="Invincible" expression="0" /><declare name="PlayerHealth" type="Real" array="False" size="" /><assign variable="PlayerHealth" expression="0" /><declare name="Rounds" type="Real" array="False" size="" /><assign variable="Rounds" expression="0" /><declare name="SCORE" type="Real" array="False" size="" /><assign variable="SCORE" expression="0" /><declare name="Shopprice" type="Real" array="False" size="" /><assign variable="Shopprice" expression="0" /><declare name="Spawnposition" ty