xpos" /><assign variable="ymain" expression="ypos" /></while><output expression="&quot;--- MESAJ PRIMIT: A start game ---&quot;" /><assign variable="Coins" expression="0" /><assign variable="Bombskill" expression="0" /><output expression="MesajStartwaves" /><assign variable="EnemiesKilled" expression="0" /><assign variable="PlayerHealth" expression="150" /><assign variable="Incombat" expression="1" /><while expression="true"><assign variable="maxHealth" expression="(150 + (25 * 0))" /><if expression="(PlayerHealth &gt; maxHealth)"><then><assign variable="PlayerHealth" expression="maxHealth" /></then><else /></if><if expression="(PlayerHealth &lt; 0.1)"><then><output expression="MesajGameover" /></then><else /></if><if expression="(0 &amp;&amp; (Dashcd = 0))"><then><for variable="i" start="1" end="10" direction="inc" step="1"><assign variable="Invincible" expression="0.1" /></for><assign variable="Dashcd" expression="0.3" /></then><else /></if></while><output expression="&quot;--- MESAJ PRIMIT: A start game ---&quot;" /><assign variable="Invincible" expression="0" /><while expression="true"><if expression="(Invincible &gt; 0)"><then><assign variable="Invincible" expression="Invincible + -0.05" /><output expression="&quot;Asteptand 0.05 secunde&quot;" /><output expression="MesajInvincibilitysprite" /></then><else><assign variable="Invincible" expression="0" /><output expression="MesajNormalsprite" /><if expression="(Invincible &lt; 0)"><then><assign variable="Invincible" expression="0" /></then><else /></if></else></if></while><output expression="&quot;--- MESAJ PRIMIT: A start game ---&quot;" /><assign variable="Dashcd" expression="0" /><while expression="true"><if expression="(Dashcd &gt; 0)"><then><assign variable="Dashcd" expression="Dashcd + -0.05" /><output expression="&quot;Asteptand 0.05 secunde&quot;" /></then><else><assign variable="Dashcd" expression="0" /></else></if></while><output expression="&quot;--- MESAJ PRIMIT: Game over ---&quot;" /><output expression="&quot;Program oprit&quot;" /><output expression="&quot;--- START CLONA: Ant queen ---&quot;" /><while expression="true"><if expression="(Invincible &gt; 0)"><then><assign variable="Invincible" expression="Invincible + -0.05" /></then><else><assign variable="Invincible" expression="0" /></else></if></while><output expression="&quot;--- START CLONA: Ant queen ---&quot;" /><assign variable="xpos" expression="0" /><assign variable="ypos" expression="150" /><output expression="&quot;Sprite visible&quot;" /><while expression="true"><for variable="i" start="1" end="40" direction="inc" step="1"><assign variable="xpos" expression="xpos + cos((90 - directie) * 3.141592653589793 / 180) * 1" /><assign variable="ypos" expression="ypos + sin((90 - directie) * 3.141592653589793 / 180) * 1" /><assign variable="directie" expression="90" /></for><assign variable="Bossattack" expression="(Random(3 - 1 + 1) + 1)" /><if expression="(Bossattack = 1)"><then><output expression="&quot;Asteptand 0.5 secunde&quot;" /></then><else /></if><if expression="(Bossattack = 2)"><then><output expression="&quot;Asteptand 1 secunde&quot;" /><output expression="MesajSpawnlarva" /><output expression="&quot;Asteptand 2 secunde&quot;" /></then><else /></if><if expression="(Bossattack = 3)"><then><output expression="&quot;Asteptand 2 secunde&quot;" /><output expression="MesajTrowsack" /><output expression="&quot;Asteptand 1 secunde&quot;" /></then><else /></if></while><output expression="&quot;--- START CLONA: Ant queen ---&quot;" /><while expression="true"><if expression="0"><then><output expression="MesajTookdamage" /></then><else /></if></while><output expression="&quot;--- START CLONA: Ant queen ---&quot;" /><assign variable="Health" expression="1000" /><assign variable="Invincible" expression="0" /><while expression="true"><output expression="Health" /><assign variable="xAntqueen" expression="xpos" /><assign variable="yAntQueen" expression="ypos" /><if expression="(0 &amp;&amp; (Invincible = 0))"><then><assign variable="Invincible" expression="0.5" /><assign variable="Health" expression="Health + (0 - Weapondamage)" /><if expression="(Health &lt; 1)"><then><assign variable="EnemiesKilled" expression="EnemiesKilled + 1" /><assign variable="Coins" expression="Coins + 200" /><assign variable="Area" expression="Area + 1" /><output expression="MesajClearenemies" /></then><else /></if></then><else /></if><if expression="(0 &amp;&amp; (Invincible = 0))"><then><assign variable="Invincible" expression="1" /><assign variable="Health" expression="Health + (0 - (20 + (4 * (0 - 1))))" /><if expression="(Health &lt; 1)"><then><assign variable="EnemiesKilled" expression="EnemiesKilled + 1" /><assign variable="Coins" expression="Coins + 200" /><assign variable="Area" expression="Area + 1" /><output expression="MesajClearenemies" /></then><else /></if></then><else /></if><if expression="(0 &amp;&amp; (Invincible = 0))"><then><assign variable="Invincible" expression="1" /><assign variable="Health" expression="Health + (0 - (20 + (4 * (0 - 1))))" /><if expression="(Health &lt; 1)"><then><assign variable="EnemiesKilled" expression="EnemiesKilled + 1" /><assign variable="Coins" expression="Coins + 200" /><assign variable="Area" expression="Area + 1" /><output expression="MesajClearenemies" /></then><else /></if></then><else /></if><if expression="(0 &amp;&amp; (Invincible = 0))"><then><assign variable="Invincible" expression="1" /><assign variable="Health" expression="Health + (0 - (30 + (15 * 0)))" /><if expression="(Health &lt; 1)"><then><assign variable="EnemiesKilled" expression="EnemiesKilled + 1" /><assign variable="Coins" expression="Coins + 200" /><assign variable="Area" expression="Area + 1" /><output expression="MesajClearenemies" /></then><else /></if></then><else /></if><if expression="(0 &amp;&amp; (Invincible = 0))"><then><assign variable="Invincible" expression="1" /><assign variable="Health" expression="Health + (0 - (30 + (15 * 0)))" /><if expression="(Health &lt